{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "framework": "static",
  "public": true,
  "regions": ["iad1"],
  "rewrites": [],
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/forgot-password.html"
    },
    {
      "source": "/clarity",
      "destination": "/clarity.html"
    },
    {
      "source": "/confidence",
      "destination": "/confidence.html"
    },
    {
      "source": "/critical-thinking",
      "destination": "/critical-thinking.html"
    },
    {
      "source": "/ai-coach",
      "destination": "/ai-coach.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
